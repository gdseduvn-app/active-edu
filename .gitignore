# ── Backup files ─────────────────────────────────────────────
*.bak
*.backup
*.orig

# ── Sensitive / environment files ────────────────────────────
.env
.env.*
!.env.example
config.local.json
secrets.json
*.pem
*.key
service-account*.json

# ── Worker secrets (never commit real values) ─────────────────
worker/.dev.vars

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Wrangler local cache ──────────────────────────────────────
.wrangler/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor files ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
