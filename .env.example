# ─── AURA AdaptLearn LMS — Environment Template ──────────────────────────────
# Copy this file to .env and fill in every value before starting Docker Compose.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=adaptlearn
POSTGRES_USER=adaptlearn
POSTGRES_PASSWORD=change_me_strong_password

# Fully-qualified DSN used by lms-api (pg) and agent (asyncpg)
DATABASE_URL=postgresql://adaptlearn:change_me_strong_password@postgres:5432/adaptlearn

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key_change_me
MINIO_USE_SSL=false
MINIO_BUCKET_CONTENT=content
MINIO_BUCKET_UPLOADS=uploads

# ── JWT (HS256 shared secret — or replace with RS256 key pair) ────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_rs256_private_key_here
JWT_PUBLIC_KEY=your_jwt_rs256_public_key_here
JWT_ALGORITHM=HS256
# Token lifetimes (seconds)
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Internal service authentication ───────────────────────────────────────────
# Shared secret for lms-api → agent calls (X-Internal-Key header)
# Generate with: openssl rand -hex 32
INTERNAL_KEY=strong_random_internal_key

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@thuthiem.edu.vn
SMTP_PASS=your_smtp_password
SMTP_FROM="THPT Thủ Thiêm <noreply@thuthiem.edu.vn>"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://learn.thuthiem.edu.vn

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Next.js Frontend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://learn.thuthiem.edu.vn/api/v1
NEXT_PUBLIC_AGENT_URL=https://learn.thuthiem.edu.vn/agent/api/v1

# ── Gamification defaults ─────────────────────────────────────────────────────
XP_PER_LESSON_COMPLETE=100
XP_PER_QUIZ_PERFECT=200
XP_PER_FLASHCARD_REVIEW=10
STREAK_GRACE_PERIOD_HOURS=24
